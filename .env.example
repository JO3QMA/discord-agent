# Required
CURSOR_API_KEY=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=
# Optional: comma-separated channel IDs (empty = all). Threads under a listed parent are allowed.
# DISCORD_ALLOWED_CHANNEL_IDS=123,456
# Optional: require @bot mention on messages (slash commands ignore this). true/false, default false
DISCORD_REQUIRE_MENTION=false
# Optional: guild id for instant slash-command sync (otherwise global, up to ~1h)
# DISCORD_GUILD_ID=

# Paths (host defaults for local; Docker overrides)
DATA_DIR=./data
AGENT_CWD=./workspace

# Agent
CURSOR_MODEL=composer-2.5
MEMORY_NOTIFICATIONS=on

# Tailscale (compose)
TS_AUTHKEY=
TZ=Asia/Tokyo
