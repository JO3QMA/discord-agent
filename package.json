{
  "name": "cursor-discord-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Discord gateway over Cursor SDK with Hermes-style memory/skills learning loop",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "check:memory": "tsx src/cli/check-memory.ts",
    "check:mcp": "tsx src/cli/check-mcp.ts",
    "check:search": "tsx src/cli/check-search.ts",
    "smoke:sdk": "tsx src/cli/smoke-sdk.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cursor/sdk": "1.0.23",
    "@discordjs/voice": "^0.19.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "discord.js": "14.27.0",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "tweetnacl": "^1.0.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "tsx": "4.20.5",
    "typescript": "5.9.3"
  }
}
